# Terraform — state files and secrets (tfvars.example is kept)
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
infrastructure/modules/compute/builds/

# Lambda deployment packages (built by Terraform at apply time)
*.zip

# Lambda bundled/extracted dependencies — never commit these
backend/**/*.dist-info/
backend/**/numpy*/
backend/**/numpy.libs/
backend/**/cv2/
backend/**/opencv_python_headless*/
backend/**/__MACOSX/
backend/**/*.weights
backend/**/*.so

# Environment / secrets
.env
.env.local
.env*.local
config.ini
secrets.json

# Logs and temp files
*.log
*.tmp
*.bak

# Test coverage
.coverage
htmlcov/

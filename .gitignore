# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# AI agent tooling
.claude/
.cursor/
.aider*
.continue/
.codeium/
.copilot/
.github/copilot*

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

